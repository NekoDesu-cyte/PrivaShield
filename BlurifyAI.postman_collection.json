{
	"info": {
		"_postman_id": "privashield-ai-api",
		"name": "Blurify AI API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/",
					"host": ["{{base_url}}"],
					"path": [""]
				}
			}
		},
		{
			"name": "Process Image",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.globals.set(\"last_image_id\", jsonData.image_id);",
							"pm.globals.set(\"detected_entities\", JSON.stringify(jsonData.detected_entities));",
							"pm.globals.set(\"sample_bbox\", jsonData.detected_entities[0] ? jsonData.detected_entities[0].bbox : [0,0,0,0]);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": "",
							"description": "Image file to process (JPG/PNG)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/image/process",
					"host": ["{{base_url}}"],
					"path": ["api", "image", "process"]
				}
			}
		},
		{
			"name": "Finalize Image",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"image_id\": \"{{last_image_id}}\",\n    \"blur_areas\": [\n        {\n            \"x\": 100,\n            \"y\": 200,\n            \"w\": 150,\n            \"h\": 40\n        }\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/image/finalize",
					"host": ["{{base_url}}"],
					"path": ["api", "image", "finalize"]
				}
			}
		},
		{
			"name": "Download Result",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/api/image/download/{{last_image_id}}_proc.png",
					"host": ["{{base_url}}"],
					"path": ["api", "image", "download", "{{last_image_id}}_proc.png"]
				}
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		}
	]
}
